<?xml version="1.0" encoding="UTF-8"?>
<structural_model name="Example3_Beam_With_Inclined_Truss_Supports">

  <metadata>
    <title>Continuous Beam a–e with Inclined Truss Supports bf and dg</title>
    <description>Four-span continuous beam fixed at both ends. Three frame elements: a-b, b-d, d-e. Two inclined truss members bf and dg at 60 degrees from horizontal, 10 m tall, pinned at base. 20 kN point load at midpoint of b-d span. E=200 GPa. Beam: A=15000mm2, I=7e8mm4. Truss: A=10000mm2.</description>
  </metadata>

  <units length="m" force="kN"/>

  <materials>
    <material id="steel_200" name="Steel 200 GPa" E="2.0e8"/>
  </materials>

  <sections>
    <section id="beam_sec"  name="Beam Section"  A="1.5e-2" I="7.0e-4"/>
    <section id="truss_sec" name="Truss Section" A="1.0e-2"/>
  </sections>

  <nodes>
    <node id="1" x="0.0"     y="0.0"/>
    <node id="2" x="12.0"    y="0.0"/>
    <node id="3" x="36.0"    y="0.0"/>
    <node id="4" x="48.0"    y="0.0"/>
    <node id="5" x="6.2265"  y="-10.0"/>
    <node id="6" x="41.7735" y="-10.0"/>
  </nodes>

  <elements>
    <frame id="F1" node_i="1" node_j="2" material="steel_200" section="beam_sec"/>
    <frame id="F2" node_i="2" node_j="3" material="steel_200" section="beam_sec"/>
    <frame id="F3" node_i="3" node_j="4" material="steel_200" section="beam_sec"/>
    <truss id="T1" node_i="5" node_j="2" material="steel_200" section="truss_sec"/>
    <truss id="T2" node_i="6" node_j="3" material="steel_200" section="truss_sec"/>
  </elements>

  <boundary_conditions>
    <support node="1" type="fixed"/>
    <support node="4" type="fixed"/>
    <support node="5" type="pin"/>
    <support node="6" type="pin"/>
  </boundary_conditions>

  <load_cases>
    <load_case id="LC1" name="20 kN downward at midpoint of span b-d">
      <member_point_load element="F2" position="12.0" fy="-20.0" fef_condition="fixed-fixed"/>
    </load_case>
  </load_cases>

</structural_model>