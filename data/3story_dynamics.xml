<?xml version="1.0" encoding="UTF-8"?>
<structural_model name="CE586_HW4_3Story_Dynamics_General">
  <metadata>
    <title>3-Level General Dynamic Model</title>
    <description>
      General node-DOF dynamic input using the same outer naming convention as the static solver XML files.
      The model is not defined by frame/truss element types. The solver reads nodes, selected DOFs, mass,
      stiffness, damping, excitation, and requested outputs.
    </description>
  </metadata>

  <units length="m" force="kN" time="s" mass="tonne" acceleration="m/s2"/>

  <parameters>
    <parameter id="g" value="9.80665" unit="m/s2"/>
  </parameters>

  <nodes>
    <node id="1" x="0.0" y="0.0"/>
    <node id="2" x="0.0" y="3.0"/>
    <node id="3" x="0.0" y="6.0"/>
    <node id="4" x="0.0" y="9.0"/>
  </nodes>

  <boundary_conditions>
    <support node="1" type="fixed"/>
  </boundary_conditions>

  <dynamic_properties>
    <active_dofs>
      <active_dof id="u1" node="2" dof="ux"/>
      <active_dof id="u2" node="3" dof="ux"/>
      <active_dof id="u3" node="4" dof="ux"/>
    </active_dofs>

    <lumped_masses>
      <lumped_mass node="2" dof="ux" value="20.0"/>
      <lumped_mass node="3" dof="ux" value="15.0"/>
      <lumped_mass node="4" dof="ux" value="15.0"/>
    </lumped_masses>

    <system_matrices dof_order="u1,u2,u3">
      <mass_matrix unit="tonne">
        <row>20.0 0.0 0.0</row>
        <row>0.0 15.0 0.0</row>
        <row>0.0 0.0 15.0</row>
      </mass_matrix>

      <stiffness_matrix unit="kN/m">
        <row>12800.0 -6400.0 0.0</row>
        <row>-6400.0 9600.0 -3200.0</row>
        <row>0.0 -3200.0 3200.0</row>
      </stiffness_matrix>

      <influence_vector direction="ux">
        <value dof="u1">1.0</value>
        <value dof="u2">1.0</value>
        <value dof="u3">1.0</value>
      </influence_vector>
    </system_matrices>

    <damping_models>
      <rayleigh_damping id="D1" damping_ratio="0.05" mode_i="1" mode_j="2" alpha="auto" beta="auto"/>
    </damping_models>

    <ground_motions>
      <ground_motion id="GM1" file="ground_motion.txt" time_column="time" acceleration_column="ag" acceleration_unit="m/s2" scale_factor="1.0"/>
    </ground_motions>
  </dynamic_properties>

  <load_cases>
    <load_case id="MODAL" name="Undamped modal analysis">
      <analysis type="modal" modes="3" damping="none" normalize="mass"/>
    </load_case>

    <load_case id="THA" name="Time history analysis">
      <analysis type="time_history" method="newmark_average_acceleration" ground_motion="GM1" damping="D1" gamma="0.5" beta="0.25"/>
    </load_case>

    <load_case id="RSA" name="Response spectrum analysis">
      <analysis type="response_spectrum" source="ground_motion" ground_motion="GM1" damping_ratio="0.05" modes="3"/>
      <combination_rule type="abssum"/>
      <combination_rule type="srss"/>
      <combination_rule type="cqc"/>
    </load_case>

    <load_case id="ESLFP" name="Equivalent static lateral force procedure">
      <analysis type="equivalent_static" spectrum="design_spectrum"/>
    </load_case>
  </load_cases>

  <spectra>
    <spectrum id="design_spectrum" damping_ratio="0.05" acceleration_unit="g">
      <point T="0.0" A="0.4"/>
      <point T="0.15" A="1.0"/>
      <point T="0.60" A="1.0"/>
      <segment from_T="0.60" expression="(0.6/T)^0.8"/>
    </spectrum>
  </spectra>

  <result_requests>
    <node_set id="floor_nodes" nodes="2,3,4"/>
    <dof_set id="lateral_dofs" dofs="u1,u2,u3"/>
    <response_quantity id="floor_displacements" type="displacement" node_set="floor_nodes" direction="ux"/>
    <response_quantity id="story_drifts" type="relative_displacement" node_pairs="2-1,3-2,4-3" direction="ux"/>
    <response_quantity id="story_shears" type="recovered_force" source="stiffness_times_displacement" dof_set="lateral_dofs"/>
    <response_quantity id="base_shear" type="reaction" node="1" direction="ux"/>
    <response_quantity id="base_moment" type="moment" about_node="1"/>
    <plot_request id="mode_shapes" type="mode_shape" node_set="floor_nodes" direction="ux"/>
    <plot_request id="displacement_history" type="time_history" quantity="floor_displacements"/>
    <plot_request id="response_spectrum" type="spectrum" spectrum="design_spectrum"/>
    <plot_request id="base_response_history" type="time_history" quantity="base_shear,base_moment"/>
  </result_requests>
</structural_model>
